---
/**
 * 智能链接：外链自动 target=_blank + rel；内部路径过 withBase。
 * 老站很多条目外链到微信公众号，故需要区分。
 */
import { withBase, isExternal } from '@lib/utils';

interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
const external = isExternal(href);
const finalHref = external ? href : withBase(href);
---

<a
  href={finalHref}
  class={className}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <slot />
</a>
