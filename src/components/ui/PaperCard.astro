---
/**
 * 论文卡片：缩略图 + 方块日期徽章 + 标题 + 详情。
 * 复刻老站视觉记忆点：白卡片 + navy 顶边 + crimson 日期块 + 悬浮图片放大。
 * 首页最新论文轮播与日后 /publications 页共用。
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { dateBadge } from '@lib/utils';
import SmartLink from './SmartLink.astro';

interface Props {
  paper: CollectionEntry<'publications'>;
}

const { paper } = Astro.props;
const { title, thumbnail, venue, badge } = paper.data;
const { day, ym } = dateBadge(paper.data.date);
// 详情：暂链到 /publications（子页面重建前的落点）。日后可改为 /publications/<id>。
const href = `/publications#${paper.id}`;
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-xl bg-white shadow-[var(--shadow-card)] ring-1 ring-black/[0.04] transition-all duration-300 ease-[var(--ease-out)] hover:-translate-y-1.5 hover:shadow-[var(--shadow-card-hover)]"
>
  <!-- 顶部品牌色描边：hover 时从 navy 过渡到更亮 -->
  <span
    class="absolute inset-x-0 top-0 z-20 h-1 bg-navy transition-colors duration-300 group-hover:bg-crimson"
    aria-hidden="true"></span>
  <SmartLink href={href} class="flex h-full flex-col">
    <div class="relative aspect-[16/10] overflow-hidden bg-muted">
      {
        thumbnail ? (
          <Image
            src={thumbnail}
            alt={title}
            width={480}
            height={300}
            class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-ink-soft">VLR</div>
        )
      }
      <!-- 渐隐遮罩，让日期徽章更清晰 -->
      <div
        class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-black/25 to-transparent"
        aria-hidden="true"></div>
      <!-- 方块日期徽章 -->
      <div
        class="absolute bottom-3 left-4 z-10 rounded bg-crimson px-2.5 py-1.5 text-center text-white shadow-lg"
      >
        <div class="text-lg font-bold leading-none tracking-tight">{day}</div>
        <div class="mt-1 text-[10px] font-medium leading-none opacity-95">{ym}</div>
      </div>
    </div>

    <div class="flex flex-1 flex-col px-5 pb-5 pt-5">
      {
        (venue || badge) && (
          <div class="mb-2.5 flex flex-wrap items-center gap-2">
            {venue && (
              <span class="text-[11px] font-semibold uppercase tracking-wide text-navy">
                {venue}
              </span>
            )}
            {badge && (
              <span class="rounded-full bg-crimson/10 px-2 py-0.5 text-[10px] font-semibold text-crimson">
                {badge}
              </span>
            )}
          </div>
        )
      }
      <h3
        class="line-clamp-3 flex-1 text-sm font-medium leading-relaxed text-ink transition-colors duration-200 group-hover:text-crimson"
      >
        {title}
      </h3>
      <span
        class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-crimson/90 transition-all group-hover:gap-1.5 group-hover:text-crimson"
      >
        详情 <span aria-hidden="true">›</span>
      </span>
    </div>
  </SmartLink>
</article>
