---
/**
 * 新闻卡片：封面 + 分类标签 + 日期 + 标题 + 摘要。
 * 外链新闻（微信等）直接跳外部；否则进站内详情页。
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { isoDate, withBase, isExternal } from '@lib/utils';

interface Props {
  item: CollectionEntry<'news'>;
}

const { item } = Astro.props;
const { title, cover, category, excerpt, external } = item.data;
const href = external ?? withBase(`/news/post/${item.id}`);
const ext = external ? isExternal(external) : false;
---

<article
  class="group flex flex-col overflow-hidden rounded-xl bg-white shadow-[var(--shadow-card)] ring-1 ring-black/[0.04] transition-all duration-300 ease-[var(--ease-out)] hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
>
  <a
    href={href}
    class="flex h-full flex-col"
    {...ext ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  >
    <div class="relative aspect-[16/9] overflow-hidden bg-muted">
      {
        cover ? (
          <Image
            src={cover}
            alt={title}
            width={480}
            height={270}
            class="h-full w-full object-cover transition-transform duration-500 ease-[var(--ease-out)] group-hover:scale-105"
          />
        ) : (
          <div class="relative flex h-full w-full items-center justify-center overflow-hidden bg-gradient-to-br from-navy to-navy-700">
            {/* 装饰光圈，呼应品牌 */}
            <span
              class="absolute -right-6 -top-8 h-28 w-28 rounded-full border border-white/10"
              aria-hidden="true"
            />
            <span
              class="absolute -bottom-10 -left-8 h-32 w-32 rounded-full border border-white/[0.07]"
              aria-hidden="true"
            />
            {/* 眼睛/光圈标志 */}
            <svg
              viewBox="0 0 120 92"
              fill="none"
              class="h-14 w-14 text-white/25 transition-transform duration-500 ease-[var(--ease-out)] group-hover:scale-110"
              aria-hidden="true"
            >
              <path
                d="M60 8 C30 8 8 32 4 46 C8 60 30 84 60 84 C90 84 112 60 116 46 C112 32 90 8 60 8 Z"
                stroke="currentColor"
                stroke-width="5"
                stroke-linejoin="round"
              />
              <circle cx="60" cy="46" r="23" stroke="currentColor" stroke-width="5" />
              <circle cx="60" cy="46" r="6" fill="currentColor" />
            </svg>
          </div>
        )
      }
      <span
        class="absolute left-3 top-3 rounded-full bg-crimson px-2.5 py-0.5 text-[11px] font-semibold text-white shadow"
      >
        {category}
      </span>
    </div>

    <div class="flex flex-1 flex-col p-5">
      <time class="text-xs text-ink-soft">{isoDate(item.data.date)}</time>
      <h3
        class="mt-1.5 line-clamp-2 font-semibold leading-relaxed text-ink transition-colors group-hover:text-crimson"
      >
        {title}
      </h3>
      {excerpt && <p class="mt-2 line-clamp-3 flex-1 text-sm text-ink-soft">{excerpt}</p>}
      <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-crimson/90">
        {ext ? '查看原文' : '阅读全文'}
        <span
          class="transition-transform duration-200 group-hover:translate-x-0.5"
          aria-hidden="true">›</span
        >
      </span>
    </div>
  </a>
</article>
