---
/**
 * 研究方向总览页（中英共用）。locale 决定页头语言。
 * 方向详情正文仅中文，故英文卡片链接指向中文详情页。
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import { withBase } from '@lib/utils';
import { useTranslations, type Locale } from '@/i18n/ui';

interface Props {
  locale?: Locale;
}
const { locale = 'zh' } = Astro.props;
const t = useTranslations(locale);
const homeHref = locale === 'en' ? withBase('/en/') : withBase('/');

const directions = (await getCollection('research')).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);
---

<BaseLayout title={t('page.research.title')} description={t('page.research.subtitle')}>
  <PageHeader
    title={t('page.research.title')}
    subtitle={t('page.research.subtitle')}
    breadcrumbs={[
      { label: t('common.home'), href: homeHref },
      { label: t('page.research.title') },
    ]}
  />

  <div class="container-vlr py-12 md:py-16">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        directions.map((d) => (
          <a
            href={withBase(`/research/${d.id}`)}
            class="group relative flex flex-col overflow-hidden rounded-xl bg-white p-6 shadow-[var(--shadow-card)] ring-1 ring-black/[0.04] transition-all duration-300 ease-[var(--ease-out)] hover:-translate-y-1 hover:shadow-[var(--shadow-card-hover)]"
          >
            <span
              class="absolute inset-x-0 top-0 h-1 bg-navy transition-colors duration-300 group-hover:bg-crimson"
              aria-hidden="true"
            />
            <h2 class="text-lg font-bold text-navy transition-colors group-hover:text-crimson">
              {d.data.title}
            </h2>
            {d.data.summary && (
              <p class="mt-3 line-clamp-4 text-sm leading-relaxed text-ink-soft">{d.data.summary}</p>
            )}
            <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-crimson/90">
              {t('common.readMore')} <span aria-hidden="true">›</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
