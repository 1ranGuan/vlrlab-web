---
/**
 * 通知公告列表页（中英共用）。locale 决定页头/界面语言；公告内容保持中文。
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import SmartLink from '@components/ui/SmartLink.astro';
import { isoDate, withBase } from '@lib/utils';
import { useTranslations, type Locale } from '@/i18n/ui';

interface Props {
  locale?: Locale;
}
const { locale = 'zh' } = Astro.props;
const t = useTranslations(locale);
const homeHref = locale === 'en' ? withBase('/en/') : withBase('/');
const pinnedLabel = locale === 'en' ? 'Pinned' : '置顶';

const items = (await getCollection('announcements', (a) => !a.data.draft)).sort((a, b) => {
  if (!!a.data.pinned !== !!b.data.pinned) return a.data.pinned ? -1 : 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});
---

<BaseLayout title={t('page.announcements.title')} description={t('page.announcements.title')}>
  <PageHeader
    title={t('page.announcements.title')}
    breadcrumbs={[
      { label: t('common.home'), href: homeHref },
      { label: t('page.announcements.title') },
    ]}
  />

  <div class="container-vlr py-12 md:py-16">
    <ul class="mx-auto max-w-3xl divide-y divide-line overflow-hidden rounded-xl bg-white shadow-[var(--shadow-card)] ring-1 ring-black/[0.04]">
      {
        items.map((item) => {
          // 详情页仅中文（内容中文），英文列表也链到中文详情。
          const href = item.data.external ?? withBase(`/announcements/${item.id}`);
          const ext = !!item.data.external;
          return (
            <li>
              <SmartLink
                href={href}
                class="group flex items-center gap-4 px-6 py-4 transition-colors hover:bg-muted"
              >
                <span class="inline-block shrink-0 rounded-full bg-crimson/10 px-2.5 py-0.5 text-[11px] font-semibold text-crimson">
                  {item.data.category}
                </span>
                {item.data.pinned && (
                  <span class="inline-block shrink-0 rounded bg-navy/10 px-1.5 py-0.5 text-[10px] font-semibold text-navy">
                    {pinnedLabel}
                  </span>
                )}
                <span class="min-w-0 flex-1 truncate font-medium text-ink transition-colors group-hover:text-crimson">
                  {item.data.title}
                </span>
                <time class="hidden shrink-0 text-xs text-ink-soft sm:block">
                  {isoDate(item.data.date)}
                </time>
                <span class="shrink-0 text-crimson/70" aria-hidden="true">
                  {ext ? '↗' : '›'}
                </span>
              </SmartLink>
            </li>
          );
        })
      }
    </ul>
  </div>
</BaseLayout>
