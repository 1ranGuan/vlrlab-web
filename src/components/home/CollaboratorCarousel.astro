---
/**
 * 合作者轮播（老站 main4 / my2Swiper）：圆形头像 + 姓名的横向 scroll-snap 轨道。
 * 数据来自 src/data/collaborators.yaml，头像按 id 从 src/assets/collaborators 匹配。
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Section from '@components/ui/Section.astro';
import SectionTitle from '@components/ui/SectionTitle.astro';
import SmartLink from '@components/ui/SmartLink.astro';
import { useTranslations, type Locale } from '@/i18n/ui';

interface Props {
  locale?: Locale;
}
const { locale = 'zh' } = Astro.props;
const t = useTranslations(locale);

const photos = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/collaborators/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);

const people = (await getCollection('collaborators')).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999)
);

function resolvePhoto(id: string): ImageMetadata | undefined {
  const match = Object.keys(photos).find((p) =>
    p.includes(`/collaborators/${id}.`)
  );
  return match ? photos[match]!.default : undefined;
}
---

<Section>
  <SectionTitle title={t('home.collaborators')} moreHref="/collaborators" moreLabel="Collaborators" />

  <div class="relative" data-rail>
    <div
      class="scrollbar-hide flex snap-x gap-6 overflow-x-auto scroll-smooth px-1 pb-4"
      data-rail-track
    >
      {
        people.map((person) => {
          const photo = resolvePhoto(person.id);
          return (
            <div class="flex w-[38%] shrink-0 snap-start flex-col items-center sm:w-[30%] md:w-[19%] lg:w-[15.5%]">
              <SmartLink href={person.data.url} class="group flex w-full flex-col items-center">
                <div class="aspect-square w-full overflow-hidden rounded-full bg-muted shadow-[var(--shadow-card)] ring-2 ring-transparent ring-offset-2 ring-offset-white transition-all duration-300 ease-[var(--ease-out)] group-hover:-translate-y-1 group-hover:shadow-[var(--shadow-card-hover)] group-hover:ring-crimson/60">
                  {photo ? (
                    <Image
                      src={photo}
                      alt={person.data.name}
                      width={200}
                      height={200}
                      class="h-full w-full object-cover transition-transform duration-500 ease-[var(--ease-out)] group-hover:scale-110"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center text-2xl text-ink-soft">
                      {person.data.name.charAt(0)}
                    </div>
                  )}
                </div>
                <h6 class="mt-3.5 flex min-h-[2.5rem] items-start justify-center text-center text-sm font-medium leading-snug text-ink transition-colors group-hover:text-crimson">
                  {person.data.name}
                </h6>
              </SmartLink>
            </div>
          );
        })
      }
    </div>

    <button
      class="absolute -left-3 top-[30%] z-10 hidden h-11 w-11 items-center justify-center rounded-full border border-line bg-white text-navy shadow-md transition-colors hover:bg-navy hover:text-white lg:flex"
      aria-label="上一组"
      data-rail-prev
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <button
      class="absolute -right-3 top-[30%] z-10 hidden h-11 w-11 items-center justify-center rounded-full border border-line bg-white text-navy shadow-md transition-colors hover:bg-navy hover:text-white lg:flex"
      aria-label="下一组"
      data-rail-next
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
</Section>

<style>
  .scrollbar-hide {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initCollabRails() {
    document.querySelectorAll<HTMLElement>('[data-rail]').forEach((rail) => {
      const track = rail.querySelector<HTMLElement>('[data-rail-track]');
      if (!track) return;
      const step = () => Math.round(track.clientWidth * 0.8);
      rail.querySelector('[data-rail-prev]')?.addEventListener('click', () =>
        track.scrollBy({ left: -step(), behavior: 'smooth' })
      );
      rail.querySelector('[data-rail-next]')?.addEventListener('click', () =>
        track.scrollBy({ left: step(), behavior: 'smooth' })
      );
    });
  }
  initCollabRails();
  document.addEventListener('astro:after-swap', initCollabRails);
</script>
