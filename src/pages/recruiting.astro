---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import TextPage from '@components/ui/TextPage.astro';
import pages from '@data/legacy-pages.json';
import { withBase } from '@lib/utils';

const page = pages['info/recruiting'];
---

<BaseLayout title="招聘招生信息" description="VLR 研究组招聘青年教师、博士后，招收博士、硕士研究生及本科生。">
  <PageHeader
    title="招聘招生信息"
    subtitle="诚邀青年教师、博士后加盟，欢迎博士、硕士及本科生报名。"
    breadcrumbs={[{ label: '首页', href: withBase('/') }, { label: '招聘招生信息' }]}
  />
  <div class="container-vlr py-12 md:py-16">
    <TextPage text={page.text} />
  </div>
</BaseLayout>
