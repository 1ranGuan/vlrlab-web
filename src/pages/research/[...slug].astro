---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import { withBase } from '@lib/utils';

export async function getStaticPaths() {
  const directions = await getCollection('research');
  return directions.map((d) => ({ params: { slug: d.id }, props: { entry: d } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`研究方向 · ${entry.data.title}`} description={entry.data.summary}>
  <PageHeader
    title={entry.data.title}
    breadcrumbs={[
      { label: '首页', href: withBase('/') },
      { label: '研究方向', href: withBase('/research') },
      { label: entry.data.title },
    ]}
  />

  <article class="container-vlr py-12 md:py-16">
    <div class="content-body mx-auto max-w-3xl leading-relaxed text-ink">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .content-body :global(p) {
    margin-block: 1rem;
  }
  .content-body :global(h2) {
    margin-block: 1.75rem 0.75rem;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-navy);
  }
  .content-body :global(a) {
    color: var(--color-crimson);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
