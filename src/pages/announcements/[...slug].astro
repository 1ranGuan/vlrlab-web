---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import { isoDate, withBase } from '@lib/utils';

export async function getStaticPaths() {
  const items = await getCollection(
    'announcements',
    (a) => !a.data.draft && !a.data.external
  );
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<BaseLayout title={item.data.title} description={item.data.title}>
  <PageHeader
    title={item.data.title}
    breadcrumbs={[
      { label: '首页', href: withBase('/') },
      { label: '通知公告', href: withBase('/announcements') },
      { label: item.data.category },
    ]}
  />

  <article class="container-vlr py-12 md:py-16">
    <div class="mx-auto max-w-3xl">
      <div class="mb-6 flex items-center gap-3 text-sm text-ink-soft">
        <span class="rounded-full bg-crimson/10 px-2.5 py-0.5 font-semibold text-crimson">
          {item.data.category}
        </span>
        <time>{isoDate(item.data.date)}</time>
      </div>

      <div class="content-body leading-relaxed text-ink">
        <Content />
      </div>

      <div class="mt-10 border-t border-line pt-6">
        <a
          href={withBase('/announcements')}
          class="inline-flex items-center gap-1 text-sm font-semibold text-crimson"
        >
          <span aria-hidden="true">‹</span> 返回通知公告
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .content-body :global(p) {
    margin-block: 0.75rem;
  }
  .content-body :global(a) {
    color: var(--color-crimson);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
