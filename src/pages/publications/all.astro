---
/**
 * 完整论文列表（老站「论文」栏目）：按年份分组的简洁文字列表。
 * 与「代表作论文」（/publications 卡片视图）区分。数据：src/data/publication-list.json
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import { withBase } from '@lib/utils';
import groups from '@data/publication-list.json';

const total = groups.reduce((n, g) => n + g.items.length, 0);
---

<BaseLayout title="论文" description="VLR 研究组完整论文列表。">
  <PageHeader
    title="论文"
    subtitle={`按年份收录，共 ${total} 篇。`}
    breadcrumbs={[
      { label: '首页', href: withBase('/') },
      { label: '研究成果', href: withBase('/publications') },
      { label: '论文' },
    ]}
  />

  <div class="container-vlr py-12 md:py-16">
    <div class="mx-auto max-w-4xl space-y-10">
      {
        groups.map((g) => (
          <section>
            <h2 class="mb-4 flex items-center gap-3 text-xl font-bold text-navy">
              <span class="inline-block h-5 w-1 rounded-full bg-crimson" aria-hidden="true" />
              {g.year}
              <span class="text-sm font-normal text-ink-soft">({g.items.length})</span>
            </h2>
            <ol class="space-y-2.5">
              {g.items.map((item, i) => (
                <li class="flex gap-3 text-sm leading-relaxed text-ink">
                  <span class="shrink-0 text-ink-soft">{i + 1}.</span>
                  <span>{item}</span>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
