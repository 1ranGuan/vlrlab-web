---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import TextPage from '@components/ui/TextPage.astro';
import pages from '@data/legacy-pages.json';
import { withBase } from '@lib/utils';

const page = pages['info/patents'];
---

<BaseLayout title="专利及软著" description="VLR 研究组专利与软件著作权列表。">
  <PageHeader
    title="专利及软著"
    breadcrumbs={[
      { label: '首页', href: withBase('/') },
      { label: '研究成果', href: withBase('/publications') },
      { label: '专利及软著' },
    ]}
  />
  <div class="container-vlr py-12 md:py-16">
    <TextPage text={page.text} />
  </div>
</BaseLayout>
