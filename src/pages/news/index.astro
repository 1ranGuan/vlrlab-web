---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import NewsCard from '@components/ui/NewsCard.astro';
import { getAllNews, NEWS_CATEGORIES } from '@lib/collections';
import { withBase } from '@lib/utils';

const news = await getAllNews();
---

<BaseLayout title="新闻动态" description="VLR 研究组新闻、实验室动态与学术报告。">
  <PageHeader
    title="新闻动态"
    subtitle="团队大新闻、实验室动态与学术报告。"
    breadcrumbs={[{ label: '首页', href: withBase('/') }, { label: '新闻动态' }]}
  />

  <div class="container-vlr py-12 md:py-16">
    <!-- 分类筛选 -->
    <div class="mb-8 flex flex-wrap gap-2">
      <span class="rounded-full bg-navy px-4 py-1.5 text-sm font-medium text-white">全部</span>
      {
        NEWS_CATEGORIES.map((cat) => (
          <a
            href={withBase(`/news/${cat}`)}
            class="rounded-full border border-line px-4 py-1.5 text-sm text-ink-soft transition-colors hover:border-navy hover:text-navy"
          >
            {cat}
          </a>
        ))
      }
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {news.map((item) => <NewsCard item={item} />)}
    </div>
  </div>
</BaseLayout>
