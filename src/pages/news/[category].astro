---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import NewsCard from '@components/ui/NewsCard.astro';
import { getAllNews, NEWS_CATEGORIES } from '@lib/collections';
import { withBase } from '@lib/utils';

export async function getStaticPaths() {
  const all = await getAllNews();
  return NEWS_CATEGORIES.map((category) => ({
    params: { category },
    props: { items: all.filter((n) => n.data.category === category), category },
  }));
}

const { items, category } = Astro.props;
---

<BaseLayout title={`新闻动态 · ${category}`} description={`VLR 研究组 - ${category}`}>
  <PageHeader
    title={category}
    breadcrumbs={[
      { label: '首页', href: withBase('/') },
      { label: '新闻动态', href: withBase('/news') },
      { label: category },
    ]}
  />

  <div class="container-vlr py-12 md:py-16">
    <!-- 分类筛选 -->
    <div class="mb-8 flex flex-wrap gap-2">
      <a
        href={withBase('/news')}
        class="rounded-full border border-line px-4 py-1.5 text-sm text-ink-soft transition-colors hover:border-navy hover:text-navy"
      >
        全部
      </a>
      {
        NEWS_CATEGORIES.map((cat) => (
          <a
            href={withBase(`/news/${cat}`)}
            class:list={[
              'rounded-full px-4 py-1.5 text-sm transition-colors',
              cat === category
                ? 'bg-navy font-medium text-white'
                : 'border border-line text-ink-soft hover:border-navy hover:text-navy',
            ]}
          >
            {cat}
          </a>
        ))
      }
    </div>

    {
      items.length === 0 ? (
        <p class="text-center text-ink-soft">该分类暂无内容。</p>
      ) : (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {items.map((item) => (
            <NewsCard item={item} />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
