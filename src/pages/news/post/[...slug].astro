---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import { isoDate, withBase } from '@lib/utils';

export async function getStaticPaths() {
  const news = await getCollection('news', (n) => !n.data.draft && !n.data.external);
  return news.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { title, category, cover } = item.data;
---

<BaseLayout title={title} description={item.data.excerpt ?? title}>
  <PageHeader
    title={title}
    breadcrumbs={[
      { label: '首页', href: withBase('/') },
      { label: '新闻动态', href: withBase('/news') },
      { label: category, href: withBase(`/news/${category}`) },
    ]}
  />

  <article class="container-vlr py-12 md:py-16">
    <div class="mx-auto max-w-3xl">
      <div class="mb-6 flex items-center gap-3 text-sm text-ink-soft">
        <span class="rounded-full bg-crimson/10 px-2.5 py-0.5 font-semibold text-crimson">
          {category}
        </span>
        <time>{isoDate(item.data.date)}</time>
      </div>

      {
        cover && (
          <div class="mb-8 overflow-hidden rounded-xl">
            <Image src={cover} alt={title} width={960} height={540} class="w-full object-cover" />
          </div>
        )
      }

      <div class="news-body leading-relaxed text-ink">
        <Content />
      </div>

      <div class="mt-10 border-t border-line pt-6">
        <a
          href={withBase('/news')}
          class="inline-flex items-center gap-1 text-sm font-semibold text-crimson"
        >
          <span aria-hidden="true">‹</span> 返回新闻列表
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .news-body :global(p) {
    margin-block: 1rem;
  }
  .news-body :global(h2) {
    margin-block: 1.75rem 0.75rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-navy);
  }
  .news-body :global(h3) {
    margin-block: 1.5rem 0.5rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-navy);
  }
  .news-body :global(a) {
    color: var(--color-crimson);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .news-body :global(ul),
  .news-body :global(ol) {
    margin-block: 1rem;
    padding-left: 1.5rem;
    list-style: revert;
  }
  .news-body :global(li) {
    margin-block: 0.35rem;
  }
  .news-body :global(img) {
    margin-block: 1.25rem;
    border-radius: 0.5rem;
  }
  .news-body :global(blockquote) {
    margin-block: 1rem;
    border-left: 3px solid var(--color-crimson);
    padding-left: 1rem;
    color: var(--color-ink-soft);
  }
</style>
